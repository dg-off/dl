{
  "id": "drifter_ivy_convo03",
  "lines": [
    {
      "order": 1,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo03_01",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo03_01.mp3",
      "text": "Look at us, the Sower and the Reaper.",
      "duration": 3.789
    },
    {
      "order": 2,
      "character": "Ivy",
      "audioFile": "tengu_match_start_drifter_tengu_convo03_02",
      "audioUrl": "audio/tengu_match_start_drifter_tengu_convo03_02.mp3",
      "text": "I think you may be confusing me with Mina. I don't know how to sew.",
      "duration": 4.467
    },
    {
      "order": 3,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo03_03",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo03_03.mp3",
      "text": "Sow, like farmin'?",
      "duration": 2.263
    },
    {
      "order": 4,
      "character": "Ivy",
      "audioFile": "tengu_match_start_drifter_tengu_convo03_04",
      "audioUrl": "audio/tengu_match_start_drifter_tengu_convo03_04.mp3",
      "text": "I've never been to a farm.",
      "duration": 1.559
    },
    {
      "order": 5,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo03_05",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo03_05.mp3",
      "text": "It's plantin' seeds.",
      "duration": 1.987
    },
    {
      "order": 6,
      "character": "Ivy",
      "audioFile": "tengu_match_start_drifter_tengu_convo03_06",
      "audioUrl": "audio/tengu_match_start_drifter_tengu_convo03_06.mp3",
      "text": "Sure, but I'm not a farmer, so why would you say that?",
      "duration": 3.936
    },
    {
      "order": 7,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo03_07",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo03_07.mp3",
      "text": "You save lives, and I take them.",
      "duration": 2.753
    },
    {
      "order": 8,
      "character": "Ivy",
      "audioFile": "tengu_match_start_drifter_tengu_convo03_08",
      "audioUrl": "audio/tengu_match_start_drifter_tengu_convo03_08.mp3",
      "text": "I think your analogies need some work.",
      "duration": 2.641
    }
  ]
}