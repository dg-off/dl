{
  "id": "kelvin_paradox_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Paradox",
      "audioFile": "chrono_match_start_kelvin_chrono_convo01_01",
      "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo01_01.mp3",
      "text": "I don't suppose you have any trinkets you'd be willing to donate to the Paradox museum.",
      "duration": 4.595
    },
    {
      "order": 2,
      "character": "Kelvin",
      "audioFile": "kelvin_match_start_kelvin_chrono_convo01_02",
      "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo01_02.mp3",
      "text": "Why do I have the feeling that you already robbed me.",
      "duration": 3.387
    },
    {
      "order": 3,
      "character": "Paradox",
      "audioFile": "chrono_match_start_kelvin_chrono_convo01_03",
      "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo01_03.mp3",
      "text": "Who's to say: we definitely planned on robbing you during the ritual, but my colleague may or may not have broken into your home yet.",
      "duration": 6.475
    },
    {
      "order": 4,
      "character": "Kelvin",
      "audioFile": "kelvin_match_start_kelvin_chrono_convo01_04",
      "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo01_04.mp3",
      "text": "I'm not sure what to say to that",
      "duration": 2.873
    },
    {
      "order": 5,
      "character": "Paradox",
      "audioFile": "chrono_match_start_kelvin_chrono_convo01_05",
      "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo01_05.mp3",
      "text": "Be flattered that you lived a life interesting enough to be robbed by us.",
      "duration": 3.597
    }
  ]
}