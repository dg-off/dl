{
  "id": "bebop_dynamo_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Bebop",
      "audioFile": "bebop_match_start_bebop_dynamo_convo01_01",
      "audioUrl": "audio/bebop_match_start_bebop_dynamo_convo01_01.mp3",
      "text": "So who made you?",
      "duration": 1.281
    },
    {
      "order": 2,
      "character": "Dynamo",
      "audioFile": "dynamo_match_start_bebop_dynamo_convo01_02",
      "audioUrl": "audio/dynamo_match_start_bebop_dynamo_convo01_02.mp3",
      "text": "Oh, I wasn't made - my body just was obliterataed by an astral gate.",
      "duration": 3.544
    },
    {
      "order": 3,
      "character": "Bebop",
      "audioFile": "bebop_match_start_bebop_dynamo_convo01_03",
      "audioUrl": "audio/bebop_match_start_bebop_dynamo_convo01_03.mp3",
      "text": "Shame, thought I found a kindred spirit.",
      "duration": 2.97
    },
    {
      "order": 4,
      "character": "Dynamo",
      "audioFile": "dynamo_match_start_bebop_dynamo_convo01_04",
      "audioUrl": "audio/dynamo_match_start_bebop_dynamo_convo01_04.mp3",
      "text": "Listen, we're both just a couple floating souls in iron bodies I think there's plenty of common ground.",
      "duration": 5.537
    },
    {
      "order": 5,
      "character": "Bebop",
      "audioFile": "bebop_match_start_bebop_dynamo_convo01_05",
      "audioUrl": "audio/bebop_match_start_bebop_dynamo_convo01_05.mp3",
      "text": "Suppose you're right.",
      "duration": 1.245
    }
  ]
}