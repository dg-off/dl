  "id": "holliday_ivy_convo03",
  "lines": [
    {
      "order": 1,
      "character": "Ivy",
      "audioFile": "tengu_match_start_astro_tengu_convo03_01",
      "audioUrl": "audio/tengu_match_start_astro_tengu_convo03_01.mp3",
      "text": "So what do you think of New York?",
      "duration": 2.529
    },
    {
      "order": 2,
      "character": "Holliday",
      "audioFile": "astro_match_start_astro_tengu_convo03_02",
      "audioUrl": "audio/astro_match_start_astro_tengu_convo03_02.mp3",
      "text": "I'm here to catch a killer, not go sight seeing.",
      "duration": 2.752
    },
    {
      "order": 3,
      "character": "Ivy",
      "audioFile": "tengu_match_start_astro_tengu_convo03_03",
      "audioUrl": "audio/tengu_match_start_astro_tengu_convo03_03.mp3",
      "text": "OK, so that's totally fair:  but, if you decide go sight seeing let me know.  I've only recently started leaving Spanish Harlem so it would be nice to have a someone to do stuff with that's not in my family.  Not that there's anything wrong with my family, I love-",
      "duration": 15.054
    },
    {
      "order": 4,
      "character": "Holliday",
      "audioFile": "astro_match_start_astro_tengu_convo03_04",
      "audioUrl": "audio/astro_match_start_astro_tengu_convo03_04.mp3",
      "text": "Can we focus on the shooting?",
      "duration": 1.777
    },
    {
      "order": 5,
      "character": "Ivy",
      "audioFile": "tengu_match_start_astro_tengu_convo03_05",
      "audioUrl": "audio/tengu_match_start_astro_tengu_convo03_05.mp3",
      "text": "You got it.",
      "duration": 0.776
    }
  ]
}