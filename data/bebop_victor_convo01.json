{
  "id": "bebop_victor_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Victor",
      "audioFile": "frank_match_start_frank_bebop_convo01_01",
      "audioUrl": "audio/frank_match_start_frank_bebop_convo01_01.mp3",
      "text": "You talk very fondly of your creator",
      "duration": 2.53
    },
    {
      "order": 2,
      "character": "Bebop",
      "audioFile": "bebop_match_start_frank_bebop_convo01_02",
      "audioUrl": "audio/bebop_match_start_frank_bebop_convo01_02.mp3",
      "text": "Miss Shelly is a good woman.",
      "duration": 2.06
    },
    {
      "order": 3,
      "character": "Victor",
      "audioFile": "frank_match_start_frank_bebop_convo01_03",
      "audioUrl": "audio/frank_match_start_frank_bebop_convo01_03.mp3",
      "text": "It must be nice having someone like that in your life.",
      "duration": 2.86
    },
    {
      "order": 4,
      "character": "Bebop",
      "audioFile": "bebop_match_start_frank_bebop_convo01_04",
      "audioUrl": "audio/bebop_match_start_frank_bebop_convo01_04.mp3",
      "text": "After the ritual I could introduce you to -",
      "duration": 2.333
    },
    {
      "order": 5,
      "character": "Victor",
      "audioFile": "frank_match_start_frank_bebop_convo01_05",
      "audioUrl": "audio/frank_match_start_frank_bebop_convo01_05.mp3",
      "text": "I don't want to impose.",
      "duration": 1.365
    },
    {
      "order": 6,
      "character": "Bebop",
      "audioFile": "bebop_match_start_frank_bebop_convo01_06",
      "audioUrl": "audio/bebop_match_start_frank_bebop_convo01_06.mp3",
      "text": "No imposition.  I insist.  People like us need to stick together.",
      "duration": 4.297
    },
    {
      "order": 7,
      "character": "Victor",
      "audioFile": "frank_match_start_frank_bebop_convo01_07",
      "audioUrl": "audio/frank_match_start_frank_bebop_convo01_07.mp3",
      "text": "Thank you",
      "duration": 0.733
    }
  ]
}