{
  "id": "bebop_seven_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Seven",
      "audioFile": "gigawatt_match_start_bebop_gigawatt_convo01_01",
      "audioUrl": "audio/gigawatt_match_start_bebop_gigawatt_convo01_01.mp3",
      "text": "Your attachment to your charge makes you weak Bebop",
      "duration": 3.323
    },
    {
      "order": 2,
      "character": "Bebop",
      "audioFile": "bebop_match_start_bebop_gigawatt_convo01_02",
      "audioUrl": "audio/bebop_match_start_bebop_gigawatt_convo01_02.mp3",
      "text": "No.  She gives me something to fight for.",
      "duration": 3.517
    },
    {
      "order": 3,
      "character": "Seven",
      "audioFile": "gigawatt_match_start_bebop_gigawatt_convo01_03",
      "audioUrl": "audio/gigawatt_match_start_bebop_gigawatt_convo01_03.mp3",
      "text": "I'm sure she's a lovely woman.  The fact remains that if I considered you a threat, I would go through her to get to you.",
      "duration": 7.144
    },
    {
      "order": 4,
      "character": "Bebop",
      "audioFile": "bebop_match_start_bebop_gigawatt_convo01_04",
      "audioUrl": "audio/bebop_match_start_bebop_gigawatt_convo01_04.mp3",
      "text": "Stay away from her.",
      "duration": 1.64
    },
    {
      "order": 5,
      "character": "Seven",
      "audioFile": "gigawatt_match_start_bebop_gigawatt_convo01_05",
      "audioUrl": "audio/gigawatt_match_start_bebop_gigawatt_convo01_05.mp3",
      "text": "I'm sure you'll give me no reason to say hello.",
      "duration": 2.919
    }
  ]
}