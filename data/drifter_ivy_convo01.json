{
  "id": "drifter_ivy_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo01_01",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo01_01.mp3",
      "text": "Well lookie here, \"The Savior of Spanish Harlem\" herself.",
      "duration": 5.274
    },
    {
      "order": 2,
      "character": "Ivy",
      "audioFile": "tengu_match_start_drifter_tengu_convo01_02",
      "audioUrl": "audio/tengu_match_start_drifter_tengu_convo01_02.mp3",
      "text": "I don't call myself that.",
      "duration": 1.989
    },
    {
      "order": 3,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo01_03",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo01_03.mp3",
      "text": "Legends don't get to choose what they're called.",
      "duration": 3.256
    },
    {
      "order": 4,
      "character": "Ivy",
      "audioFile": "tengu_match_start_drifter_tengu_convo01_04",
      "audioUrl": "audio/tengu_match_start_drifter_tengu_convo01_04.mp3",
      "text": "I'm not a legend.",
      "duration": 1.463
    },
    {
      "order": 5,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_tengu_convo01_05",
      "audioUrl": "audio/drifter_match_start_drifter_tengu_convo01_05.mp3",
      "text": "Yes you are.  You know it and you're afraid of it.  Don't be.",
      "duration": 5.811
    }
  ]
}