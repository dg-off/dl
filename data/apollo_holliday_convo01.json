{
  "id": "apollo_holliday_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Apollo",
      "audioFile": "fencer_match_start_fencer_astro_convo01_01",
      "audioUrl": "audio/fencer_match_start_fencer_astro_convo01_01.mp3",
      "text": "You haven't slept in days.",
      "duration": 1.74
    },
    {
      "order": 2,
      "character": "Holliday",
      "audioFile": "astro_match_start_fencer_astro_convo01_02",
      "audioUrl": "audio/astro_match_start_fencer_astro_convo01_02.mp3",
      "text": "Who are you, my mother?",
      "duration": 1.498
    },
    {
      "order": 3,
      "character": "Apollo",
      "audioFile": "fencer_match_start_fencer_astro_convo01_03",
      "audioUrl": "audio/fencer_match_start_fencer_astro_convo01_03.mp3",
      "text": "I'm the person who's putting his life in the hands of an emotional trainwreck on a suicide mission.",
      "duration": 4.603
    },
    {
      "order": 4,
      "character": "Holliday",
      "audioFile": "astro_match_start_fencer_astro_convo01_04",
      "audioUrl": "audio/astro_match_start_fencer_astro_convo01_04.mp3",
      "text": "Do I look like Grey Talon?",
      "duration": 2.251
    },
    {
      "order": 5,
      "character": "Apollo",
      "audioFile": "fencer_match_start_fencer_astro_convo01_05",
      "audioUrl": "audio/fencer_match_start_fencer_astro_convo01_05.mp3",
      "text": "Grey Talon has discipline that you could only dream about.  I'm amazed you haven't accidently fired your gun already.",
      "duration": 6.066
    },
    {
      "order": 6,
      "character": "Holliday",
      "audioFile": "astro_match_start_fencer_astro_convo01_06",
      "audioUrl": "audio/astro_match_start_fencer_astro_convo01_06.mp3",
      "text": "You're an asshole, kid.",
      "duration": 1.545
    }
  ]
}