{
  "id": "holliday_rem_convo03",
  "lines": [
    {
      "order": 1,
      "character": "Rem",
      "audioFile": "familiar_match_start_familiar_astro_convo03_01",
      "audioUrl": "audio/familiar_match_start_familiar_astro_convo03_01.mp3",
      "text": "I'm lost.  Can you help?",
      "duration": 3.073
    },
    {
      "order": 2,
      "character": "Holliday",
      "audioFile": "astro_match_start_familiar_astro_convo03_02",
      "audioUrl": "audio/astro_match_start_familiar_astro_convo03_02.mp3",
      "text": "I'm sorry, I don't know the area.  Have you talked to the police?",
      "duration": 3.897
    },
    {
      "order": 3,
      "character": "Rem",
      "audioFile": "familiar_match_start_familiar_astro_convo03_03",
      "audioUrl": "audio/familiar_match_start_familiar_astro_convo03_03.mp3",
      "text": "I'm talking to you.",
      "duration": 2.28
    },
    {
      "order": 4,
      "character": "Holliday",
      "audioFile": "astro_match_start_familiar_astro_convo03_04",
      "audioUrl": "audio/astro_match_start_familiar_astro_convo03_04.mp3",
      "text": "Have you talked to police that live here?",
      "duration": 2.522
    },
    {
      "order": 5,
      "character": "Rem",
      "audioFile": "familiar_match_start_familiar_astro_convo03_05",
      "audioUrl": "audio/familiar_match_start_familiar_astro_convo03_05.mp3",
      "text": "Why would I do that when I'm talking to you.",
      "duration": 3.796
    },
    {
      "order": 6,
      "character": "Holliday",
      "audioFile": "astro_match_start_familiar_astro_convo03_06",
      "audioUrl": "audio/astro_match_start_familiar_astro_convo03_06.mp3",
      "text": "Cause they- just stay close to me, we'll talk after The Ritual.",
      "duration": 5.371
    }
  ]
