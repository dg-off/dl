      "character": "Holliday",
      "audioFile": "astro_match_start_haze_astro_troubadour_convo03_03",
      "audioUrl": "audio/astro_match_start_haze_astro_troubadour_convo03_03.mp3",
      "text": "We didn't just stop the troubadour, you kept me from crossing a line, and I owe you for that.",
