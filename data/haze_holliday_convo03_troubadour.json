      "audioFile": "haze_match_start_haze_astro_troubadour_convo03_02",
      "audioUrl": "audio/haze_match_start_haze_astro_troubadour_convo03_02.mp3",
      "text": "No need to thank me, we were both doing our job.",
      "duration": 3.673
    },
    {
