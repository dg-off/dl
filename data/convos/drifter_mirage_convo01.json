{
  "id": "drifter_mirage_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_mirage_convo01_01",
      "audioUrl": "audio/drifter_match_start_drifter_mirage_convo01_01.mp3",
      "text": "So how much dirty work do the Djinn have you do?",
      "duration": 2.95
    },
    {
      "order": 2,
      "character": "Mirage",
      "audioFile": "mirage_match_start_drifter_mirage_convo01_02",
      "audioUrl": "audio/mirage_match_start_drifter_mirage_convo01_02.mp3",
      "text": "Nashala is woman of nobility and poise.   She doesn't ask me to do dirty work.",
      "duration": 6.055
    },
    {
      "order": 3,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_mirage_convo01_03",
      "audioUrl": "audio/drifter_match_start_drifter_mirage_convo01_03.mp3",
      "text": "I see.  So she doesn't trust you.",
      "duration": 3.287
    },
    {
      "order": 4,
      "character": "Mirage",
      "audioFile": "mirage_match_start_drifter_mirage_convo01_04",
      "audioUrl": "audio/mirage_match_start_drifter_mirage_convo01_04.mp3",
      "text": "She trusts me implicitly.",
      "duration": 2.203
    },
    {
      "order": 5,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_mirage_convo01_05",
      "audioUrl": "audio/drifter_match_start_drifter_mirage_convo01_05.mp3",
      "text": "Of course.",
      "duration": 1.263
    },
    {
      "order": 6,
      "character": "Mirage",
      "audioFile": "mirage_match_start_drifter_mirage_convo01_06",
      "audioUrl": "audio/mirage_match_start_drifter_mirage_convo01_06.mp3",
      "text": "I don't like your tone vampire",
      "duration": 2.213
    },
    {
      "order": 7,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_mirage_convo01_07",
      "audioUrl": "audio/drifter_match_start_drifter_mirage_convo01_07.mp3",
      "text": "If you don't like it now, wait till you hear the sounds I make when I'm ripping out your gullet.",
      "duration": 5.309
    },
    {
      "order": 8,
      "character": "Mirage",
      "audioFile": "mirage_match_start_drifter_mirage_convo01_08",
      "audioUrl": "audio/mirage_match_start_drifter_mirage_convo01_08.mp3",
      "text": "You dare threaten an emissary of the djinn?",
      "duration": 3.189
    },
    {
      "order": 9,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_mirage_convo01_09",
      "audioUrl": "audio/drifter_match_start_drifter_mirage_convo01_09.mp3",
      "text": "Ritual's startin' pretty boy.  We'll finish this later.",
      "duration": 5.323
    }
  ]
}