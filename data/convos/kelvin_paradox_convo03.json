{
  "id": "kelvin_paradox_convo03",
  "lines": [
    {
      "order": 1,
      "character": "Paradox",
      "audioFile": "chrono_match_start_kelvin_chrono_convo03_01",
      "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo03_01.mp3",
      "text": "You know you're held in high regard by Paradox, right?",
      "duration": 3.519
    },
    {
      "order": 2,
      "character": "Kelvin",
      "audioFile": "kelvin_match_start_kelvin_chrono_convo03_02",
      "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo03_02.mp3",
      "text": "Why?  I'm an explorer, not a theif.",
      "duration": 3.022
    },
    {
      "order": 3,
      "character": "Paradox",
      "audioFile": "chrono_match_start_kelvin_chrono_convo03_03",
      "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo03_03.mp3",
      "text": "An explorer is just a theif that specializes in stealing from the dead.",
      "duration": 3.897
    },
    {
      "order": 4,
      "character": "Kelvin",
      "audioFile": "kelvin_match_start_kelvin_chrono_convo03_04",
      "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo03_04.mp3",
      "text": "That feels like a gross oversimplification.",
      "duration": 2.98
    },
    {
      "order": 5,
      "character": "Paradox",
      "audioFile": "chrono_match_start_kelvin_chrono_convo03_05",
      "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo03_05.mp3",
      "text": "Whose got time for nuance.",
      "duration": 2.102
    }
  ]
}