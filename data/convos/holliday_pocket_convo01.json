{
  "id": "holliday_pocket_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Holliday",
      "audioFile": "astro_match_start_astro_synth_convo01_01",
      "audioUrl": "audio/astro_match_start_astro_synth_convo01_01.mp3",
      "text": "You ready for this kid?",
      "duration": 1.49
    },
    {
      "order": 2,
      "character": "Pocket",
      "audioFile": "synth_match_start_astro_synth_convo01_02",
      "audioUrl": "audio/synth_match_start_astro_synth_convo01_02.mp3",
      "text": "I'm not a kid.",
      "duration": 1.161
    },
    {
      "order": 3,
      "character": "Holliday",
      "audioFile": "astro_match_start_astro_synth_convo01_03",
      "audioUrl": "audio/astro_match_start_astro_synth_convo01_03.mp3",
      "text": "Yes.  You are.  And I need to know if I have to look after you.",
      "duration": 4.115
    },
    {
      "order": 4,
      "character": "Pocket",
      "audioFile": "synth_match_start_astro_synth_convo01_04",
      "audioUrl": "audio/synth_match_start_astro_synth_convo01_04.mp3",
      "text": "You don't.  But it's nice to hear someone say that.",
      "duration": 3.197
    }
  ]
}