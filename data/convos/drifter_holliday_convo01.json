{
  "id": "drifter_holliday_convo01",
  "lines": [
    {
      "order": 1,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_astro_convo01_01",
      "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_01.mp3",
      "text": "You're looking for The Troubadour, right?",
      "duration": 2.001
    },
    {
      "order": 2,
      "character": "Holliday",
      "audioFile": "astro_match_start_drifter_astro_convo01_02",
      "audioUrl": "audio/astro_match_start_drifter_astro_convo01_02.mp3",
      "text": "That's right.  You got a tip for me?",
      "duration": 2.517
    },
    {
      "order": 3,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_astro_convo01_03",
      "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_03.mp3",
      "text": "Yeah, you don't wanna find him.",
      "duration": 3.239
    },
    {
      "order": 4,
      "character": "Holliday",
      "audioFile": "astro_match_start_drifter_astro_convo01_04",
      "audioUrl": "audio/astro_match_start_drifter_astro_convo01_04.mp3",
      "text": "I'm getting real tired of people telling me that.",
      "duration": 2.792
    },
    {
      "order": 5,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_astro_convo01_05",
      "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_05.mp3",
      "text": "Macomb matters a lot to you, but to him it was just a fun time that will get lost in the ocean of memory.  But if you find him\u2026 if he knows he got his hooks in you?  You're going to be his hobby.",
      "duration": 13.363
    },
    {
      "order": 6,
      "character": "Holliday",
      "audioFile": "astro_match_start_drifter_astro_convo01_06",
      "audioUrl": "audio/astro_match_start_drifter_astro_convo01_06.mp3",
      "text": "What's that mean.",
      "duration": 1.218
    },
    {
      "order": 7,
      "character": "Drifter",
      "audioFile": "drifter_match_start_drifter_astro_convo01_07",
      "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_07.mp3",
      "text": "Oh I wouldn't want to spoil the surprise, but trust me Sheriff\u2026 for your sake.  Let it go.",
      "duration": 6.772
    }
  ]
}