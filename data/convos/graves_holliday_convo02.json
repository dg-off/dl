    {
      "order": 7,
      "character": "Holliday",
      "audioFile": "astro_match_start_necro_astro_convo02_07",
      "audioUrl": "audio/astro_match_start_necro_astro_convo02_07.mp3",
      "text": "You shouldn't be here.  It's not safe.",
      "duration": 2.24
    },
    {
      "order": 8,
      "character": "Graves",
      "audioFile": "necro_match_start_necro_astro_convo02_08",
      "audioUrl": "audio/necro_match_start_necro_astro_convo02_08.mp3",
      "text": "I can take care of myself",
      "duration": 1.317
    }
  ]
