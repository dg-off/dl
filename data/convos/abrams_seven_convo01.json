  "lines": [
    {
      "order": 1,
      "character": "Seven",
      "audioFile": "gigawatt_match_start_atlas_gigawatt_convo01_01",
      "audioUrl": "audio/gigawatt_match_start_atlas_gigawatt_convo01_01.mp3",
      "text": "Detective Abrams.",
      "duration": 1.526
    },
    {
      "order": 2,
      "character": "Abrams",
      "audioFile": "atlas_match_start_atlas_gigawatt_convo01_02",
      "audioUrl": "audio/atlas_match_start_atlas_gigawatt_convo01_02.mp3",
      "text": "I don't believe we've met.",
      "duration": 2.231
    },
    {
      "order": 3,
      "character": "Seven",
      "audioFile": "gigawatt_match_start_atlas_gigawatt_convo01_03",
      "audioUrl": "audio/gigawatt_match_start_atlas_gigawatt_convo01_03.mp3",
      "text": "We haven't. But I am fascinated by what you hold.",
      "duration": 3.956
    },
    {
      "order": 4,
      "character": "Abrams",
      "audioFile": "atlas_match_start_atlas_gigawatt_convo01_04",
      "audioUrl": "audio/atlas_match_start_atlas_gigawatt_convo01_04.mp3",
      "text": "If you think I'm letting you get your hands on -",
      "duration": 3.282
    },
    {
      "order": 5,
      "character": "Seven",
      "audioFile": "gigawatt_match_start_atlas_gigawatt_convo01_05",
      "audioUrl": "audio/gigawatt_match_start_atlas_gigawatt_convo01_05.mp3",
      "text": "Don't worry Detective.  I know better.",
      "duration": 3.684
    }
  ]
}