{
  "conversations": [
    {
      "conversationId": "bebop_holliday_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Holliday",
          "audioFile": "astro_match_start_bebop_astro_convo03_01",
          "audioUrl": "audio/astro_match_start_bebop_astro_convo03_01.mp3",
          "text": "I know it's against your nature, or programming, or whatever, but there are going to be times when I need you not to punch someone right after you pull them.",
          "duration": 7.904
        },
        {
          "order": 2,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_astro_convo03_02",
          "audioUrl": "audio/bebop_match_start_bebop_astro_convo03_02.mp3",
          "text": "You're right that does seem rather counter-intutive",
          "duration": 3.839
        },
        {
          "order": 3,
          "character": "Holliday",
          "audioFile": "astro_match_start_bebop_astro_convo03_03",
          "audioUrl": "audio/astro_match_start_bebop_astro_convo03_03.mp3",
          "text": "Just let me grab them them first, then feel free to beat the hell out of them.",
          "duration": 4.258
        },
        {
          "order": 4,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_astro_convo03_04",
          "audioUrl": "audio/bebop_match_start_bebop_astro_convo03_04.mp3",
          "text": "I make no promises",
          "duration": 1.504
        }
      ]
    },
    {
      "conversationId": "drifter_holliday_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_astro_convo01_01",
          "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_01.mp3",
          "text": "You're looking for The Troubadour, right?",
          "duration": 2.001
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_drifter_astro_convo01_02",
          "audioUrl": "audio/astro_match_start_drifter_astro_convo01_02.mp3",
          "text": "That's right.  You got a tip for me?",
          "duration": 2.517
        },
        {
          "order": 3,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_astro_convo01_03",
          "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_03.mp3",
          "text": "Yeah, you don't wanna find him.",
          "duration": 3.239
        },
        {
          "order": 4,
          "character": "Holliday",
          "audioFile": "astro_match_start_drifter_astro_convo01_04",
          "audioUrl": "audio/astro_match_start_drifter_astro_convo01_04.mp3",
          "text": "I'm getting real tired of people telling me that.",
          "duration": 2.792
        },
        {
          "order": 5,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_astro_convo01_05",
          "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_05.mp3",
          "text": "Macomb matters a lot to you, but to him it was just a fun time that will get lost in the ocean of memory.  But if you find him\u2026 if he knows he got his hooks in you?  You're going to be his hobby.",
          "duration": 13.363
        },
        {
          "order": 6,
          "character": "Holliday",
          "audioFile": "astro_match_start_drifter_astro_convo01_06",
          "audioUrl": "audio/astro_match_start_drifter_astro_convo01_06.mp3",
          "text": "What's that mean.",
          "duration": 1.218
        },
        {
          "order": 7,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_astro_convo01_07",
          "audioUrl": "audio/drifter_match_start_drifter_astro_convo01_07.mp3",
          "text": "Oh I wouldn't want to spoil the surprise, but trust me Sheriff\u2026 for your sake.  Let it go.",
          "duration": 6.772
        }
      ]
    },
    {
      "conversationId": "drifter_holliday_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_astro_convo02_01",
          "audioUrl": "audio/drifter_match_start_drifter_astro_convo02_01.mp3",
          "text": "Tie them down Holliday, and leave the rest to me.",
          "duration": 3.249
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_drifter_astro_convo02_02",
          "audioUrl": "audio/astro_match_start_drifter_astro_convo02_02.mp3",
          "text": "I don't take orders from you.",
          "duration": 1.663
        },
        {
          "order": 3,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_astro_convo02_03",
          "audioUrl": "audio/drifter_match_start_drifter_astro_convo02_03.mp3",
          "text": "You want 'em dead? Tie 'em down for me.",
          "duration": 3.22
        }
      ]
    }
  ]
}