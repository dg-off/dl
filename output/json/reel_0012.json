      "conversationId": "holliday_shiv_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Shiv",
          "audioFile": "shiv_match_start_astro_shiv_convo03_01",
          "audioUrl": "audio/shiv_match_start_astro_shiv_convo03_01.mp3",
          "text": "You're the one looking to kill the Troubadour, right?",
          "duration": 2.341
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_shiv_convo03_02",
          "audioUrl": "audio/astro_match_start_astro_shiv_convo03_02.mp3",
          "text": "Yeah.",
          "duration": 0.947
        },
        {
          "order": 3,
          "character": "Shiv",
          "audioFile": "shiv_match_start_astro_shiv_convo03_03",
          "audioUrl": "audio/shiv_match_start_astro_shiv_convo03_03.mp3",
          "text": "You make it out alive you should look up the Baxter society\u2026. We could use someone like you.",
          "duration": 5.757
        },
        {
          "order": 4,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_shiv_convo03_04",
          "audioUrl": "audio/astro_match_start_astro_shiv_convo03_04.mp3",
          "text": "I'll think about it\u2026",
          "duration": 1.611
        }
      ]
    },
    {
      "conversationId": "holliday_pocket_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_synth_convo01_01",
          "audioUrl": "audio/astro_match_start_astro_synth_convo01_01.mp3",
          "text": "You ready for this kid?",
          "duration": 1.49
        },
        {
          "order": 2,
          "character": "Pocket",
          "audioFile": "synth_match_start_astro_synth_convo01_02",
          "audioUrl": "audio/synth_match_start_astro_synth_convo01_02.mp3",
          "text": "I'm not a kid.",
          "duration": 1.161
        },
        {
          "order": 3,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_synth_convo01_03",
          "audioUrl": "audio/astro_match_start_astro_synth_convo01_03.mp3",
          "text": "Yes.  You are.  And I need to know if I have to look after you.",
          "duration": 4.115
        },
        {
          "order": 4,
          "character": "Pocket",
          "audioFile": "synth_match_start_astro_synth_convo01_04",
          "audioUrl": "audio/synth_match_start_astro_synth_convo01_04.mp3",
          "text": "You don't.  But it's nice to hear someone say that.",
          "duration": 3.197
        }
      ]
    },
    {
      "conversationId": "holliday_pocket_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_synth_convo02_01",
          "audioUrl": "audio/astro_match_start_astro_synth_convo02_01.mp3",
          "text": "You look like you've lived a life.",
          "duration": 2.412
        },
        {
          "order": 2,
          "character": "Pocket",
          "audioFile": "synth_match_start_astro_synth_convo02_02",
          "audioUrl": "audio/synth_match_start_astro_synth_convo02_02.mp3",
          "text": "You have no idea",
          "duration": 1.881
        },
        {
          "order": 3,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_synth_convo02_03",
          "audioUrl": "audio/astro_match_start_astro_synth_convo02_03.mp3",
          "text": "You wanna talk about it?",
          "duration": 1.442
        },
        {
          "order": 4,
          "character": "Pocket",
          "audioFile": "synth_match_start_astro_synth_convo02_04",
          "audioUrl": "audio/synth_match_start_astro_synth_convo02_04.mp3",
          "text": "I really don't.",
          "duration": 1.44
        }
      ]
    }
  ]
