    },
    {
      "conversationId": "abrams_grey talon_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_orion_convo03_01",
          "audioUrl": "audio/atlas_match_start_atlas_orion_convo03_01.mp3",
          "text": "Talon.  I know you don't care if you die, but I am highly motivated to stay alive so please don't do anything stupid.",
