        {
          "order": 2,
          "character": "Grey talon",
          "audioFile": "orion_match_start_atlas_orion_convo03_02",
          "audioUrl": "audio/orion_match_start_atlas_orion_convo03_02.mp3",
          "text": "Don't worry Abrams\u2026 I'm not dying until I have my revenge.",
          "duration": 4.416
        }
      ]
    },
    {
