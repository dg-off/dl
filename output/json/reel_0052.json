          "order": 6,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_dynamo_convo03_06",
          "audioUrl": "audio/bebop_match_start_bebop_dynamo_convo03_06.mp3",
          "text": "I like to think she is.",
          "duration": 1.529
