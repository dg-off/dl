        {
          "order": 3,
          "character": "Holliday",
          "audioFile": "astro_match_start_priest_astro_convo03_03",
          "audioUrl": "audio/astro_match_start_priest_astro_convo03_03.mp3",
          "text": "It didn't.  But it was nice that you tried.",
