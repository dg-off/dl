        }
      ]
    },
    {
      "conversationId": "holliday_viper_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo01_01",
          "audioUrl": "audio/viper_match_start_viper_astro_convo01_01.mp3",
          "text": "You're a cop right?",
          "duration": 1.46
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo01_02",
          "audioUrl": "audio/astro_match_start_viper_astro_convo01_02.mp3",
          "text": "Yeah.",
          "duration": 0.703
        },
        {
          "order": 3,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo01_03",
          "audioUrl": "audio/viper_match_start_viper_astro_convo01_03.mp3",
          "text": "Because you like the law or because you like being on a power trip?",
          "duration": 3.936
        },
        {
          "order": 4,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo01_04",
          "audioUrl": "audio/astro_match_start_viper_astro_convo01_04.mp3",
          "text": "What sort of question is that.",
          "duration": 1.65
        },
        {
          "order": 5,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo01_05",
          "audioUrl": "audio/viper_match_start_viper_astro_convo01_05.mp3",
          "text": "Hey, I'm just trying to figure out if we could be friends",
          "duration": 2.4
        },
        {
          "order": 6,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo01_06",
          "audioUrl": "audio/astro_match_start_viper_astro_convo01_06.mp3",
          "text": "I uphold the law.",
          "duration": 1.52
        },
        {
          "order": 7,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo01_07",
          "audioUrl": "audio/viper_match_start_viper_astro_convo01_07.mp3",
          "text": "We should not be friends.",
          "duration": 1.388
        }
      ]
    },
    {
      "conversationId": "holliday_viper_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo02_01",
          "audioUrl": "audio/viper_match_start_viper_astro_convo02_01.mp3",
          "text": "You look familiar.",
          "duration": 1.269
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo02_02",
          "audioUrl": "audio/astro_match_start_viper_astro_convo02_02.mp3",
          "text": "Doubt it, I'm not from around here.",
          "duration": 2.454
        },
        {
          "order": 3,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo02_03",
          "audioUrl": "audio/viper_match_start_viper_astro_convo02_03.mp3",
          "text": "Where from?",
          "duration": 0.835
        },
        {
          "order": 4,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo02_04",
          "audioUrl": "audio/astro_match_start_viper_astro_convo02_04.mp3",
          "text": "Illinois.",
          "duration": 0.864
        },
        {
          "order": 5,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo02_05",
          "audioUrl": "audio/viper_match_start_viper_astro_convo02_05.mp3",
          "text": "No shit, I did a little time in Cook County.",
          "duration": 2.972
        },
        {
          "order": 6,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo02_06",
          "audioUrl": "audio/astro_match_start_viper_astro_convo02_06.mp3",
          "text": "I'm further south.",
          "duration": 1.332
        },
        {
          "order": 7,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo02_07",
          "audioUrl": "audio/viper_match_start_viper_astro_convo02_07.mp3",
          "text": "Well if you ever find yourself in the BG, pretend you don't know me, I don't want people knowing I'm tight with a cop.",
          "duration": 7.118
        },
        {
          "order": 8,
          "character": "Holliday",
          "audioFile": "astro_match_start_viper_astro_convo02_08",
          "audioUrl": "audio/astro_match_start_viper_astro_convo02_08.mp3",
          "text": "You're not.",
          "duration": 0.881
        },
        {
          "order": 9,
          "character": "Viper",
          "audioFile": "viper_match_start_viper_astro_convo02_09",
          "audioUrl": "audio/viper_match_start_viper_astro_convo02_09.mp3",
          "text": "Exactly.",
          "duration": 1.368
        }
      ]
    }
