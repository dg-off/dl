{
  "conversations": [
    {
      "conversationId": "doorman_paige_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo02_01",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo02_01.mp3",
          "text": "So how long have you worked at The Baroness?",
          "duration": 2.243
        },
        {
          "order": 2,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo02_02",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo02_02.mp3",
          "text": "Since it's inception.",
          "duration": 1.419
        },
        {
          "order": 3,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo02_03",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo02_03.mp3",
          "text": "You must like it then.",
          "duration": 1.263
        },
        {
          "order": 4,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo02_04",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo02_04.mp3",
          "text": "Well, I tormented man for so long that serving them still retains it's novel charm.",
          "duration": 4.648
        },
        {
          "order": 5,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo02_05",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo02_05.mp3",
          "text": "What?",
          "duration": 0.586
        },
        {
          "order": 6,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo02_06",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo02_06.mp3",
          "text": "Don't worry about it, the ritual is about to begin.",
          "duration": 2.727
        }
      ]
    },
    {
      "conversationId": "doorman_paige_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo03_01",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo03_01.mp3",
          "text": "So what's your name?",
          "duration": 1.444
        },
        {
          "order": 2,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo03_02",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo03_02.mp3",
          "text": "I am The Doorman.",
          "duration": 1.846
        },
        {
          "order": 3,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo03_03",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo03_03.mp3",
          "text": "I know that's your job, but what's your name?",
          "duration": 2.724
        },
        {
          "order": 4,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo03_04",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo03_04.mp3",
          "text": "The doorman.",
          "duration": 1.656
        },
        {
          "order": 5,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo03_05",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo03_05.mp3",
          "text": "That's not your name.",
          "duration": 1.003
        },
        {
          "order": 6,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo03_06",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo03_06.mp3",
          "text": "It's not, but for my purposes in New York it helps me stay grounded that I am here to serve and not to rule.",
          "duration": 7.495
        },
        {
          "order": 7,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_doorman_convo03_07",
          "audioUrl": "audio/bookworm_match_start_bookworm_doorman_convo03_07.mp3",
          "text": "What if I called you Brian?",
          "duration": 2.296
        },
        {
          "order": 8,
          "character": "Doorman",
          "audioFile": "doorman_match_start_bookworm_doorman_convo03_08",
          "audioUrl": "audio/doorman_match_start_bookworm_doorman_convo03_08.mp3",
          "text": "No.",
          "duration": 0.382
        }
      ]
    },
    {
      "conversationId": "paige_victor_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_frank_convo01_01",
          "audioUrl": "audio/bookworm_match_start_bookworm_frank_convo01_01.mp3",
          "text": "You know earlier I made a joke about Byronic heroes but seeing you here makes it less of a joke and more like I made my high school diary come to life.",
          "duration": 7.007
        },
        {
          "order": 2,
          "character": "Victor",
          "audioFile": "frank_match_start_bookworm_frank_convo01_02",
          "audioUrl": "audio/frank_match_start_bookworm_frank_convo01_02.mp3",
          "text": "Thanks?",
          "duration": 0.77
        },
        {
          "order": 3,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_frank_convo01_03",
          "audioUrl": "audio/bookworm_match_start_bookworm_frank_convo01_03.mp3",
          "text": "Never put on a shirt.",
          "duration": 1.204
        },
        {
          "order": 4,
          "character": "Victor",
          "audioFile": "frank_match_start_bookworm_frank_convo01_04",
          "audioUrl": "audio/frank_match_start_bookworm_frank_convo01_04.mp3",
          "text": "You got it\u2026",
          "duration": 2.273
        }
      ]
    }
  ]
}