        },
        {
          "order": 4,
          "character": "Victor",
          "audioFile": "frank_match_start_bookworm_frank_convo02_04",
          "audioUrl": "audio/frank_match_start_bookworm_frank_convo02_04.mp3",
          "text": "Yes, you made your point.",
