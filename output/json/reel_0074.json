        {
          "order": 6,
          "character": "Victor",
          "audioFile": "frank_match_start_bookworm_frank_convo03_06",
          "audioUrl": "audio/frank_match_start_bookworm_frank_convo03_06.mp3",
          "text": "That's very sweet of you.  Thank you.",
          "duration": 2.614
        }
      ]
