        {
          "order": 5,
          "character": "Paige",
          "audioFile": "bookworm_match_start_bookworm_frank_convo02_05",
          "audioUrl": "audio/bookworm_match_start_bookworm_frank_convo02_05.mp3",
          "text": "You're a walking mystery novel, and I need to know everything.",
