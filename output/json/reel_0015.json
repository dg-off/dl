      "lines": [
        {
          "order": 1,
          "character": "Viscous",
          "audioFile": "viscous_match_start_astro_viscous_convo03_01",
          "audioUrl": "audio/viscous_match_start_astro_viscous_convo03_01.mp3",
          "text": "What does revenge feel like?",
          "duration": 2.188
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_viscous_convo03_02",
          "audioUrl": "audio/astro_match_start_astro_viscous_convo03_02.mp3",
          "text": "What do you mean?",
          "duration": 1.022
        },
        {
          "order": 3,
          "character": "Viscous",
          "audioFile": "viscous_match_start_astro_viscous_convo03_03",
          "audioUrl": "audio/viscous_match_start_astro_viscous_convo03_03.mp3",
          "text": "When I'm in the cube it's warm.  I like being in the cube.  You seem to like revenge so I wonder if it feels the same.",
          "duration": 7.39
        },
        {
          "order": 4,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_viscous_convo03_04",
          "audioUrl": "audio/astro_match_start_astro_viscous_convo03_04.mp3",
          "text": "No Viscous.  It, um.  It doesn't feel warm.",
          "duration": 3.882
        },
        {
          "order": 5,
          "character": "Viscous",
          "audioFile": "viscous_match_start_astro_viscous_convo03_05",
          "audioUrl": "audio/viscous_match_start_astro_viscous_convo03_05.mp3",
          "text": "But it feels good",
          "duration": 1.479
        },
        {
          "order": 6,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_viscous_convo03_06",
          "audioUrl": "audio/astro_match_start_astro_viscous_convo03_06.mp3",
          "text": "No.  It really doesn\u2019t.",
          "duration": 2.417
        },
        {
          "order": 7,
          "character": "Viscous",
          "audioFile": "viscous_match_start_astro_viscous_convo03_07",
          "audioUrl": "audio/viscous_match_start_astro_viscous_convo03_07.mp3",
          "text": "Then why do you want to live in it?",
          "duration": 1.904
        },
        {
          "order": 8,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_viscous_convo03_08",
          "audioUrl": "audio/astro_match_start_astro_viscous_convo03_08.mp3",
          "text": "Because there's nothing else I can do about it.",
          "duration": 2.559
        },
        {
          "order": 8,
          "character": "Holliday",
          "audioFile": "astro_match_start_astro_viscous_convo03_08_02",
          "audioUrl": "audio/astro_match_start_astro_viscous_convo03_08_02.mp3",
          "text": "Because there's nothing else I can do about it.",
          "duration": 2.462
        }
      ]
    },
    {
