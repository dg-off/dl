        {
          "order": 5,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_dynamo_convo01_05",
          "audioUrl": "audio/bebop_match_start_bebop_dynamo_convo01_05.mp3",
          "text": "Suppose you're right.",
          "duration": 1.245
        }
      ]
