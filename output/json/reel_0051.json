        },
        {
          "order": 4,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_bebop_dynamo_convo01_04",
          "audioUrl": "audio/dynamo_match_start_bebop_dynamo_convo01_04.mp3",
          "text": "Listen, we're both just a couple floating souls in iron bodies I think there's plenty of common ground.",
          "duration": 5.537
