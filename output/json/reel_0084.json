{
  "conversations": [
    {
      "conversationId": "kelvin_paradox_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Kelvin",
          "audioFile": "kelvin_match_start_kelvin_chrono_convo02_01",
          "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo02_01.mp3",
          "text": "You have so many gifts and yet you waste them on petty theft and childish stunts.",
          "duration": 5.406
        },
        {
          "order": 2,
          "character": "Paradox",
          "audioFile": "chrono_match_start_kelvin_chrono_convo02_02",
          "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo02_02.mp3",
          "text": "That's a little judgemental.",
          "duration": 2.125
        },
        {
          "order": 3,
          "character": "Kelvin",
          "audioFile": "kelvin_match_start_kelvin_chrono_convo02_03",
          "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo02_03.mp3",
          "text": "It's the truth.",
          "duration": 1.398
        },
        {
          "order": 4,
          "character": "Paradox",
          "audioFile": "chrono_match_start_kelvin_chrono_convo02_04",
          "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo02_04.mp3",
          "text": "The heart wants what the heart wants Kelvin.",
          "duration": 2.599
        }
      ]
    },
    {
      "conversationId": "kelvin_paradox_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Paradox",
          "audioFile": "chrono_match_start_kelvin_chrono_convo03_01",
          "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo03_01.mp3",
          "text": "You know you're held in high regard by Paradox, right?",
          "duration": 3.519
        },
        {
          "order": 2,
          "character": "Kelvin",
          "audioFile": "kelvin_match_start_kelvin_chrono_convo03_02",
          "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo03_02.mp3",
          "text": "Why?  I'm an explorer, not a theif.",
          "duration": 3.022
        },
        {
          "order": 3,
          "character": "Paradox",
          "audioFile": "chrono_match_start_kelvin_chrono_convo03_03",
          "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo03_03.mp3",
          "text": "An explorer is just a theif that specializes in stealing from the dead.",
          "duration": 3.897
        },
        {
          "order": 4,
          "character": "Kelvin",
          "audioFile": "kelvin_match_start_kelvin_chrono_convo03_04",
          "audioUrl": "audio/kelvin_match_start_kelvin_chrono_convo03_04.mp3",
          "text": "That feels like a gross oversimplification.",
          "duration": 2.98
        },
        {
          "order": 5,
          "character": "Paradox",
          "audioFile": "chrono_match_start_kelvin_chrono_convo03_05",
          "audioUrl": "audio/chrono_match_start_kelvin_chrono_convo03_05.mp3",
          "text": "Whose got time for nuance.",
          "duration": 2.102
        }
      ]
    },
    {
      "conversationId": "grey talon_paradox_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo01_01",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo01_01.mp3",
          "text": "The Baxter Society pulling you out of retirement?",
          "duration": 3.153
        },
        {
          "order": 2,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo01_02",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo01_02.mp3",
          "text": "This has nothing to do with The Society.",
          "duration": 2.503
        },
        {
          "order": 3,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo01_03",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo01_03.mp3",
          "text": "If it did would you tell me?",
          "duration": 2.31
        },
        {
          "order": 4,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo01_04",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo01_04.mp3",
          "text": "I'm not in the mood for games Paradox.",
          "duration": 2.441
        },
        {
          "order": 5,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo01_05",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo01_05.mp3",
          "text": "I really thought you'd be more fun.",
          "duration": 2.756
        },
        {
          "order": 6,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo01_06",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo01_06.mp3",
          "text": "Sorry to dissapoint you.",
          "duration": 1.59
        }
      ]
    }
  ]
