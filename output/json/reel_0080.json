{
  "conversations": [
    {
      "conversationId": "dynamo_paradox_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_dynamo_chrono_convo02_01",
          "audioUrl": "audio/dynamo_match_start_dynamo_chrono_convo02_01.mp3",
          "text": "I am absolutely fascinated by your organization Paradox",
          "duration": 3.047
        },
        {
          "order": 2,
          "character": "Paradox",
          "audioFile": "chrono_match_start_dynamo_chrono_convo02_02",
          "audioUrl": "audio/chrono_match_start_dynamo_chrono_convo02_02.mp3",
          "text": "Thank you very much Professor.",
          "duration": 2.052
        },
        {
          "order": 3,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_dynamo_chrono_convo02_03",
          "audioUrl": "audio/dynamo_match_start_dynamo_chrono_convo02_03.mp3",
          "text": "I took Marla to the last pop-up, truly wonderful things to behold.",
          "duration": 4.648
        },
        {
          "order": 4,
          "character": "Paradox",
          "audioFile": "chrono_match_start_dynamo_chrono_convo02_04",
          "audioUrl": "audio/chrono_match_start_dynamo_chrono_convo02_04.mp3",
          "text": "I think you'll enjoy our next event, I'll make sure you get in.",
          "duration": 3.862
        },
        {
          "order": 5,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_dynamo_chrono_convo02_05",
          "audioUrl": "audio/dynamo_match_start_dynamo_chrono_convo02_05.mp3",
          "text": "I can't wait.",
          "duration": 0.902
        }
      ]
    },
    {
      "conversationId": "dynamo_paradox_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_dynamo_chrono_convo03_01",
          "audioUrl": "audio/dynamo_match_start_dynamo_chrono_convo03_01.mp3",
          "text": "Can I ask you a question?",
          "duration": 1.139
        },
        {
          "order": 2,
          "character": "Paradox",
          "audioFile": "chrono_match_start_dynamo_chrono_convo03_02",
          "audioUrl": "audio/chrono_match_start_dynamo_chrono_convo03_02.mp3",
          "text": "Sure.",
          "duration": 0.941
        },
        {
          "order": 3,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_dynamo_chrono_convo03_03",
          "audioUrl": "audio/dynamo_match_start_dynamo_chrono_convo03_03.mp3",
          "text": "Why do keep stealing things?  Don't you have enough?",
          "duration": 2.729
        },
        {
          "order": 4,
          "character": "Paradox",
          "audioFile": "chrono_match_start_dynamo_chrono_convo03_04",
          "audioUrl": "audio/chrono_match_start_dynamo_chrono_convo03_04.mp3",
          "text": "Why do you keep reading books?  Haven't you read enough?",
          "duration": 3.229
        },
        {
          "order": 5,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_dynamo_chrono_convo03_05",
          "audioUrl": "audio/dynamo_match_start_dynamo_chrono_convo03_05.mp3",
          "text": "Point taken.",
          "duration": 0.913
        }
      ]
    },
    {
      "conversationId": "lady geist_paradox_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_ghost_chrono_convo01_01",
          "audioUrl": "audio/ghost_match_start_ghost_chrono_convo01_01.mp3",
          "text": "I heard a rumor that you had one of my husband's paintings",
          "duration": 3.404
        },
        {
          "order": 2,
          "character": "Paradox",
          "audioFile": "chrono_match_start_ghost_chrono_convo01_02",
          "audioUrl": "audio/chrono_match_start_ghost_chrono_convo01_02.mp3",
          "text": "I wouldn't know, art's not really my thing.",
          "duration": 2.555
        },
        {
          "order": 3,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_ghost_chrono_convo01_03",
          "audioUrl": "audio/ghost_match_start_ghost_chrono_convo01_03.mp3",
          "text": "I want it back.",
          "duration": 1.293
        },
        {
          "order": 4,
          "character": "Paradox",
          "audioFile": "chrono_match_start_ghost_chrono_convo01_04",
          "audioUrl": "audio/chrono_match_start_ghost_chrono_convo01_04.mp3",
          "text": "I don't blame you.",
          "duration": 1.307
        },
        {
          "order": 5,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_ghost_chrono_convo01_05",
          "audioUrl": "audio/ghost_match_start_ghost_chrono_convo01_05.mp3",
          "text": "I am not someone to play games with.",
          "duration": 2.718
        },
        {
          "order": 6,
          "character": "Paradox",
          "audioFile": "chrono_match_start_ghost_chrono_convo01_06",
          "audioUrl": "audio/chrono_match_start_ghost_chrono_convo01_06.mp3",
          "text": "Lady, we already robbed you.  You're exactly the person to play games with.  If you want the painting back I recommend that you try to find it.  Good luck.",
          "duration": 10.231
        }
      ]
    }
  ]
}