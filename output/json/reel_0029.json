{
  "conversations": [
    {
      "conversationId": "graves_holliday_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Holliday",
          "audioFile": "astro_match_start_necro_astro_convo03_01",
          "audioUrl": "audio/astro_match_start_necro_astro_convo03_01.mp3",
          "text": "So do they give you the pack of cloves when you become a theatre kid?  Or  was that something you brought to the table all on your own.",
          "duration": 6.95
        },
        {
          "order": 2,
          "character": "Graves",
          "audioFile": "necro_match_start_necro_astro_convo03_02",
          "audioUrl": "audio/necro_match_start_necro_astro_convo03_02.mp3",
          "text": "I hope you get shot.",
          "duration": 1.012
        },
        {
          "order": 3,
          "character": "Holliday",
          "audioFile": "astro_match_start_necro_astro_convo03_03",
          "audioUrl": "audio/astro_match_start_necro_astro_convo03_03.mp3",
          "text": "I'm making conversation.",
          "duration": 1.503
        },
        {
          "order": 4,
          "character": "Graves",
          "audioFile": "necro_match_start_necro_astro_convo03_04",
          "audioUrl": "audio/necro_match_start_necro_astro_convo03_04.mp3",
          "text": "And I'm hoping you get shot.",
          "duration": 1.505
        }
      ]
    },
    {
      "conversationId": "holliday_venator_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Venator",
          "audioFile": "priest_match_start_priest_astro_convo01_01",
          "audioUrl": "audio/priest_match_start_priest_astro_convo01_01.mp3",
          "text": "What happened in Macomb wasn't your fault, child.",
          "duration": 3.208
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_priest_astro_convo01_02",
          "audioUrl": "audio/astro_match_start_priest_astro_convo01_02.mp3",
          "text": "You weren't there.",
          "duration": 1.136
        },
        {
          "order": 3,
          "character": "Venator",
          "audioFile": "priest_match_start_priest_astro_convo01_03",
          "audioUrl": "audio/priest_match_start_priest_astro_convo01_03.mp3",
          "text": "No.  But I've failed before.  You can't let it consume you.",
          "duration": 4.23
        },
        {
          "order": 4,
          "character": "Holliday",
          "audioFile": "astro_match_start_priest_astro_convo01_04",
          "audioUrl": "audio/astro_match_start_priest_astro_convo01_04.mp3",
          "text": "I can't not care.",
          "duration": 1.408
        },
        {
          "order": 5,
          "character": "Venator",
          "audioFile": "priest_match_start_priest_astro_convo01_05",
          "audioUrl": "audio/priest_match_start_priest_astro_convo01_05.mp3",
          "text": "I didn't say don't care.  Pain and anger are fires that burn in all of us, but it needs to be tended lest it destroys you.",
          "duration": 8.319
        },
        {
          "order": 6,
          "character": "Holliday",
          "audioFile": "astro_match_start_priest_astro_convo01_06",
          "audioUrl": "audio/astro_match_start_priest_astro_convo01_06.mp3",
          "text": "Yeah?  And how do you tend it?",
          "duration": 2.829
        },
        {
          "order": 7,
          "character": "Venator",
          "audioFile": "priest_match_start_priest_astro_convo01_07",
          "audioUrl": "audio/priest_match_start_priest_astro_convo01_07.mp3",
          "text": "You're about to find out.",
          "duration": 1.549
        }
      ]
    },
    {
      "conversationId": "holliday_venator_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Venator",
          "audioFile": "priest_match_start_priest_astro_convo02_01",
          "audioUrl": "audio/priest_match_start_priest_astro_convo02_01.mp3",
          "text": "Harden your heart, sheriff\u2026 you can't let your sense of law and order get in the way of what needs to be done.",
          "duration": 5.77
        },
        {
          "order": 2,
          "character": "Holliday",
          "audioFile": "astro_match_start_priest_astro_convo02_02",
          "audioUrl": "audio/astro_match_start_priest_astro_convo02_02.mp3",
          "text": "Don't worry Father\u2026 the law is the farthest thing from driving me.",
          "duration": 5.098
        }
      ]
    }
  ]
