        {
          "order": 5,
          "character": "Seven",
          "audioFile": "gigawatt_match_start_gigawatt_chrono_convo03_05",
          "audioUrl": "audio/gigawatt_match_start_gigawatt_chrono_convo03_05.mp3",
          "text": "We'll speak later.",
          "duration": 1.332
        }
      ]
    },
    {
