        {
          "order": 3,
          "character": "Paradox",
          "audioFile": "chrono_match_start_gigawatt_chrono_convo02_03",
          "audioUrl": "audio/chrono_match_start_gigawatt_chrono_convo02_03.mp3",
          "text": "I won't be threatened by you Seven",
