        {
          "order": 3,
          "character": "Seven",
          "audioFile": "gigawatt_match_start_gigawatt_chrono_convo03_03",
          "audioUrl": "audio/gigawatt_match_start_gigawatt_chrono_convo03_03.mp3",
          "text": "But if I proposed  something\u2026 would you consider it?",
