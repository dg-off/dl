        {
          "order": 4,
          "character": "Seven",
          "audioFile": "gigawatt_match_start_gigawatt_chrono_convo02_04",
          "audioUrl": "audio/gigawatt_match_start_gigawatt_chrono_convo02_04.mp3",
          "text": "And yet you just were.",
