        {
          "order": 5,
          "character": "Paradox",
          "audioFile": "chrono_match_start_gigawatt_chrono_convo02_05",
          "audioUrl": "audio/chrono_match_start_gigawatt_chrono_convo02_05.mp3",
          "text": "You have until the end of the ritual to consider your answer.",
          "duration": 3.103
        }
      ]
    },
    {
      "conversationId": "paradox_seven_convo03",
      "lines": [
        {
