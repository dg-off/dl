          "order": 3,
          "character": "Drifter",
          "audioFile": "drifter_match_start_drifter_lash_convo02_03",
          "audioUrl": "audio/drifter_match_start_drifter_lash_convo02_03.mp3",
          "text": "Yeah it's you.",
          "duration": 1.496
