{
  "conversations": [
    {
      "conversationId": "grey talon_paradox_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo02_01",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo02_01.mp3",
          "text": "I'd love to see the inside of The Manor House",
          "duration": 2.702
        },
        {
          "order": 2,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo02_02",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo02_02.mp3",
          "text": "I wouldn't recommend breaking in.",
          "duration": 2.153
        },
        {
          "order": 3,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo02_03",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo02_03.mp3",
          "text": "Oh I know what happened to the last member of Paradox that tried to steal from The Baxter society.  That's why I want you to get me in.",
          "duration": 7.699
        },
        {
          "order": 4,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo02_04",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo02_04.mp3",
          "text": "Never going to happen.",
          "duration": 1.634
        },
        {
          "order": 5,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo02_05",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo02_05.mp3",
          "text": "We'll see.",
          "duration": 1.097
        }
      ]
    },
    {
      "conversationId": "grey talon_paradox_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo03_01",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo03_01.mp3",
          "text": "You're looking spry for an old man.",
          "duration": 2.153
        },
        {
          "order": 2,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo03_02",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo03_02.mp3",
          "text": "Spry enough.",
          "duration": 0.928
        },
        {
          "order": 3,
          "character": "Paradox",
          "audioFile": "chrono_match_start_orion_chrono_convo03_03",
          "audioUrl": "audio/chrono_match_start_orion_chrono_convo03_03.mp3",
          "text": "Don't expect me to carry you if you lag behind.",
          "duration": 3.019
        },
        {
          "order": 4,
          "character": "Grey talon",
          "audioFile": "orion_match_start_orion_chrono_convo03_04",
          "audioUrl": "audio/orion_match_start_orion_chrono_convo03_04.mp3",
          "text": "The only thing I expect from Paradox is style over substance.",
          "duration": 3.754
        }
      ]
    },
    {
      "conversationId": "doorman_lady geist_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_doorman_ghost_convo01_01",
          "audioUrl": "audio/ghost_match_start_doorman_ghost_convo01_01.mp3",
          "text": "You work at The Baroness, yes?",
          "duration": 2.451
        },
        {
          "order": 2,
          "character": "Doorman",
          "audioFile": "doorman_match_start_doorman_ghost_convo01_02",
          "audioUrl": "audio/doorman_match_start_doorman_ghost_convo01_02.mp3",
          "text": "Indeed.",
          "duration": 0.815
        },
        {
          "order": 3,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_doorman_ghost_convo01_03",
          "audioUrl": "audio/ghost_match_start_doorman_ghost_convo01_03.mp3",
          "text": "That hotel used to be magical until its standards went to hell.",
          "duration": 4.354
        },
        {
          "order": 4,
          "character": "Doorman",
          "audioFile": "doorman_match_start_doorman_ghost_convo01_04",
          "audioUrl": "audio/doorman_match_start_doorman_ghost_convo01_04.mp3",
          "text": "I will lodge your complaint with management",
          "duration": 3.673
        },
        {
          "order": 5,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_doorman_ghost_convo01_05",
          "audioUrl": "audio/ghost_match_start_doorman_ghost_convo01_05.mp3",
          "text": "Be sure that you do.",
          "duration": 1.527
        },
        {
          "order": 6,
          "character": "Doorman",
          "audioFile": "doorman_match_start_doorman_ghost_convo01_06",
          "audioUrl": "audio/doorman_match_start_doorman_ghost_convo01_06.mp3",
          "text": "I will.",
          "duration": 0.914
        }
      ]
    }
  ]
}