{
  "conversations": [
    {
      "conversationId": "bebop_lady geist_convo02",
      "lines": [
        {
          "order": 1,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_ghost_convo02_01",
          "audioUrl": "audio/bebop_match_start_bebop_ghost_convo02_01.mp3",
          "text": "Geist\u2026 are you Dr. Johann's sister?",
          "duration": 2.883
        },
        {
          "order": 2,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_bebop_ghost_convo02_02",
          "audioUrl": "audio/ghost_match_start_bebop_ghost_convo02_02.mp3",
          "text": "I'm flattered but no.",
          "duration": 1.994
        },
        {
          "order": 3,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_ghost_convo02_03",
          "audioUrl": "audio/bebop_match_start_bebop_ghost_convo02_03.mp3",
          "text": "You have his eyes",
          "duration": 1.293
        },
        {
          "order": 4,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_bebop_ghost_convo02_04",
          "audioUrl": "audio/ghost_match_start_bebop_ghost_convo02_04.mp3",
          "text": "He has mine.",
          "duration": 1.359
        }
      ]
    },
    {
      "conversationId": "bebop_lady geist_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_bebop_ghost_convo03_01",
          "audioUrl": "audio/ghost_match_start_bebop_ghost_convo03_01.mp3",
          "text": "You're not one of those machines that value human life are you?",
          "duration": 4.062
        },
        {
          "order": 2,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_ghost_convo03_02",
          "audioUrl": "audio/bebop_match_start_bebop_ghost_convo03_02.mp3",
          "text": "Not particularly, beyond a few noteable excpetions.",
          "duration": 3.343
        },
        {
          "order": 3,
          "character": "Lady geist",
          "audioFile": "ghost_match_start_bebop_ghost_convo03_03",
          "audioUrl": "audio/ghost_match_start_bebop_ghost_convo03_03.mp3",
          "text": "Wonderful.  We'll get along just fine",
          "duration": 3.417
        }
      ]
    },
    {
      "conversationId": "bebop_seven_convo01",
      "lines": [
        {
          "order": 1,
          "character": "Seven",
          "audioFile": "gigawatt_match_start_bebop_gigawatt_convo01_01",
          "audioUrl": "audio/gigawatt_match_start_bebop_gigawatt_convo01_01.mp3",
          "text": "Your attachment to your charge makes you weak Bebop",
          "duration": 3.323
        },
        {
          "order": 2,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_gigawatt_convo01_02",
          "audioUrl": "audio/bebop_match_start_bebop_gigawatt_convo01_02.mp3",
          "text": "No.  She gives me something to fight for.",
          "duration": 3.517
        },
        {
          "order": 3,
          "character": "Seven",
          "audioFile": "gigawatt_match_start_bebop_gigawatt_convo01_03",
          "audioUrl": "audio/gigawatt_match_start_bebop_gigawatt_convo01_03.mp3",
          "text": "I'm sure she's a lovely woman.  The fact remains that if I considered you a threat, I would go through her to get to you.",
          "duration": 7.144
        },
        {
          "order": 4,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_gigawatt_convo01_04",
          "audioUrl": "audio/bebop_match_start_bebop_gigawatt_convo01_04.mp3",
          "text": "Stay away from her.",
          "duration": 1.64
        },
        {
          "order": 5,
          "character": "Seven",
          "audioFile": "gigawatt_match_start_bebop_gigawatt_convo01_05",
          "audioUrl": "audio/gigawatt_match_start_bebop_gigawatt_convo01_05.mp3",
          "text": "I'm sure you'll give me no reason to say hello.",
          "duration": 2.919
        }
      ]
    }
  ]
}