{
  "conversations": [
    {
      "conversationId": "abrams_dynamo_convo03",
      "lines": [
        {
          "order": 1,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_atlas_dynamo_convo03_01",
          "audioUrl": "audio/dynamo_match_start_atlas_dynamo_convo03_01.mp3",
          "text": "I don't suppose I could take a look at that tome when all of this is over.",
          "duration": 4.111
        },
        {
          "order": 2,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_convo03_02",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_convo03_02.mp3",
          "text": "Professor, if things go our way there won't be a tome for you to look at.",
          "duration": 4.217
        }
      ]
    },
    {
      "conversationId": "abrams_dynamo_convo01_oathkeeper",
      "lines": [
        {
          "order": 1,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_atlas_dynamo_oathkeeper_convo01_01",
          "audioUrl": "audio/dynamo_match_start_atlas_dynamo_oathkeeper_convo01_01.mp3",
          "text": "I heard a rumor that you moved in with Lady Geist.",
          "duration": 2.289
        },
        {
          "order": 2,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_oathkeeper_convo01_02",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_oathkeeper_convo01_02.mp3",
          "text": "Don't want to talk about it.",
          "duration": 1.445
        },
        {
          "order": 3,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_atlas_dynamo_oathkeeper_convo01_03",
          "audioUrl": "audio/dynamo_match_start_atlas_dynamo_oathkeeper_convo01_03.mp3",
          "text": "Who would have thought that a simple business card could start a star-crossed romance?",
          "duration": 3.832
        },
        {
          "order": 4,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_oathkeeper_convo01_04",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_oathkeeper_convo01_04.mp3",
          "text": "Nothing romantic about it, pal.",
          "duration": 2.411
        },
        {
          "order": 5,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_atlas_dynamo_oathkeeper_convo01_05",
          "audioUrl": "audio/dynamo_match_start_atlas_dynamo_oathkeeper_convo01_05.mp3",
          "text": "Not yet.",
          "duration": 0.756
        },
        {
          "order": 6,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_oathkeeper_convo01_06",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_oathkeeper_convo01_06.mp3",
          "text": "Not ever!",
          "duration": 1.362
        }
      ]
    },
    {
      "conversationId": "abrams_dynamo_convo02_oathkeeper",
      "lines": [
        {
          "order": 1,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_oathkeeper_convo02_01",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_oathkeeper_convo02_01.mp3",
          "text": "Sorry about crashing your party.",
          "duration": 2.288
        },
        {
          "order": 2,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_atlas_dynamo_oathkeeper_convo02_02",
          "audioUrl": "audio/dynamo_match_start_atlas_dynamo_oathkeeper_convo02_02.mp3",
          "text": "No apologies needed, it wasn't my party. Did you ever meet up with Lady Geist?",
          "duration": 4.36
        },
        {
          "order": 3,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_oathkeeper_convo02_03",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_oathkeeper_convo02_03.mp3",
          "text": "No. Never called back.",
          "duration": 2.85
        },
        {
          "order": 4,
          "character": "Dynamo",
          "audioFile": "dynamo_match_start_atlas_dynamo_oathkeeper_convo02_04",
          "audioUrl": "audio/dynamo_match_start_atlas_dynamo_oathkeeper_convo02_04.mp3",
          "text": "Sorry to hear that.",
          "duration": 0.969
        },
        {
          "order": 5,
          "character": "Abrams",
          "audioFile": "atlas_match_start_atlas_dynamo_oathkeeper_convo02_05",
          "audioUrl": "audio/atlas_match_start_atlas_dynamo_oathkeeper_convo02_05.mp3",
          "text": "It's probably for the best, I heard that woman's bad news.",
          "duration": 3.799
        }
      ]
    }
  ]
}