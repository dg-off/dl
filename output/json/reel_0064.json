          "order": 2,
          "character": "Bebop",
          "audioFile": "bebop_match_start_bebop_tengu_convo03_02",
          "audioUrl": "audio/bebop_match_start_bebop_tengu_convo03_02.mp3",
          "text": "That sounds rather nice Ivy, thank you.",
          "duration": 2.937
        }
      ]
    },
    {
